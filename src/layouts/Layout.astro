---
import "../styles/global.css"; 

interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Personal CV and Portfolio for Artyom Voronov, Gameplay Developer specializing in Unreal Engine." />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
	<link rel="icon" type="image/png" sizes="96x96" href="/favicons/favicon-96x96.png" />
	<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
	<link rel="icon" href="/favicons/favicon.ico" sizes="any" />
	<link rel="manifest" href="/site.webmanifest" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <div class="header-content">
                <nav class="main-navigation">
                    <ul>
						<li><a href="#hero">Home</a></li>
                        <li><a href="#experience">Experience</a></li>
                        <li><a href="#projects">Projects</a></li>
                        <li><a href="#contact">Contact</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
	<div id="top">
		<main>
			<slot />
		</main>
	</div> 

    <!-- Site Footer -->
	<footer class="site-footer">
		<div class="container">
			<p>&copy; {new Date().getFullYear()} Artyom Voronov. <a target="_blank" rel="noopener noreferrer" href="https://github.com/MrEluzium/portfolio-space">Source code</a></p>
		</div>
   </footer>
         
   <script>
	// @ts-nocheck
	document.addEventListener('DOMContentLoaded', () => {
		const body = document.body;
		const header = document.querySelector('.site-header');
		const sections = Array.from(document.querySelectorAll('main section[id]'));
		const navLinks = Array.from(document.querySelectorAll('.main-navigation a'));

		if (!header || sections.length === 0 || navLinks.length === 0) {
			return;
		}

		const collapseThreshold = 24;
		const expandThreshold = 6;
		const bottomThreshold = 2;
		const headerOffsetGap = 8;
		const activationGrace = 16;
		const scrollArrivalTolerance = 2;
		const interruptKeys = new Set(['ArrowUp', 'ArrowDown', 'PageUp', 'PageDown', 'Home', 'End', ' ', 'Spacebar']);

		const sectionById = new Map(
			sections
				.map((section) => [section.id, section])
				.filter(([id]) => Boolean(id)),
		);
		const linkBySectionId = new Map();
		navLinks.forEach((link) => {
			const href = link.getAttribute('href');
			if (!href || !href.startsWith('#')) {
				return;
			}

			const sectionId = href.slice(1);
			if (sectionById.has(sectionId)) {
				linkBySectionId.set(sectionId, link);
			}
		});

		let isHeaderCollapsed = body.classList.contains('header-scrolled');
		let activeSectionId = null;
		let pendingClickSectionId = null;
		let pendingTargetScrollY = null;
		let frameRequested = false;

		function setHeaderCollapsed(nextValue) {
			if (nextValue === isHeaderCollapsed) {
				return;
			}

			isHeaderCollapsed = nextValue;
			body.classList.toggle('header-scrolled', nextValue);
		}

		function updateHeaderCollapseState() {
			const scrollY = window.scrollY;
			if (!isHeaderCollapsed && scrollY >= collapseThreshold) {
				setHeaderCollapsed(true);
			} else if (isHeaderCollapsed && scrollY <= expandThreshold) {
				setHeaderCollapsed(false);
			}
		}

		function updateHeaderOffsetVar() {
			const headerHeight = header.getBoundingClientRect().height;
			const offset = Math.max(0, Math.ceil(headerHeight + headerOffsetGap));
			document.documentElement.style.setProperty('--header-offset', `${offset}px`);
		}

		function getCurrentHeaderOffset() {
			const rawOffset = Number.parseFloat(
				getComputedStyle(document.documentElement).getPropertyValue('--header-offset'),
			);
			if (Number.isFinite(rawOffset)) {
				return rawOffset;
			}

			return Math.max(0, Math.ceil(header.getBoundingClientRect().height + headerOffsetGap));
		}

		function getTargetScrollY(section) {
			const sectionTop = window.scrollY + section.getBoundingClientRect().top;
			const target = sectionTop - getCurrentHeaderOffset();
			const maxScroll = Math.max(0, document.documentElement.scrollHeight - window.innerHeight);
			return Math.min(Math.max(0, target), maxScroll);
		}

		function getActivationLine() {
			return Math.max(header.getBoundingClientRect().bottom + headerOffsetGap, getCurrentHeaderOffset());
		}

		function setActiveSection(sectionId) {
			if (sectionId === activeSectionId) {
				return;
			}

			navLinks.forEach((link) => link.classList.remove('active-link'));

			if (sectionId) {
				const link = linkBySectionId.get(sectionId);
				if (link) {
					link.classList.add('active-link');
					activeSectionId = sectionId;
					return;
				}
			}

			activeSectionId = null;
		}

		function getScrollDrivenSectionId() {
			const viewportBottom = window.scrollY + window.innerHeight;
			const pageHeight = document.documentElement.scrollHeight;

			if (viewportBottom >= pageHeight - bottomThreshold) {
				return sections[sections.length - 1].id;
			}

			const activationLine = getActivationLine();
			let candidateIndex = -1;

			for (let index = 0; index < sections.length; index++) {
				const section = sections[index];
				if (section.getBoundingClientRect().top <= activationLine) {
					candidateIndex = index;
				} else {
					break;
				}
			}

			if (candidateIndex < 0) {
				return sections[0].id;
			}

			if (candidateIndex < sections.length - 1) {
				const nextSection = sections[candidateIndex + 1];
				const nextTop = nextSection.getBoundingClientRect().top;
				if (nextTop - activationLine <= activationGrace) {
					return nextSection.id;
				}
			}

			return sections[candidateIndex].id;
		}

		function hasReachedPendingTarget() {
			if (!pendingClickSectionId) {
				return false;
			}

			const targetSection = sectionById.get(pendingClickSectionId);
			if (!targetSection) {
				return true;
			}

			if (pendingTargetScrollY !== null) {
				if (Math.abs(window.scrollY - pendingTargetScrollY) <= scrollArrivalTolerance) {
					return true;
				}
			}

			const targetRect = targetSection.getBoundingClientRect();
			const activationLine = getActivationLine();
			const isActivationInsideTarget = targetRect.top <= activationLine && targetRect.bottom >= activationLine;
			if (isActivationInsideTarget) {
				return true;
			}

			const isFirstSection = targetSection === sections[0];
			if (isFirstSection && window.scrollY <= expandThreshold) {
				return true;
			}

			const isLastSection = targetSection === sections[sections.length - 1];
			const viewportBottom = window.scrollY + window.innerHeight;
			const pageHeight = document.documentElement.scrollHeight;
			if (isLastSection && viewportBottom >= pageHeight - bottomThreshold) {
				return true;
			}

			return false;
		}

		function clearPendingTarget() {
			if (!pendingClickSectionId) {
				return;
			}

			pendingClickSectionId = null;
			pendingTargetScrollY = null;
		}

		function update() {
			updateHeaderCollapseState();
			updateHeaderOffsetVar();

			if (pendingClickSectionId) {
				if (hasReachedPendingTarget()) {
					const completedTargetId = pendingClickSectionId;
					clearPendingTarget();
					const scrollDrivenSectionId = getScrollDrivenSectionId();
					setActiveSection(
						scrollDrivenSectionId === completedTargetId ? scrollDrivenSectionId : completedTargetId,
					);
				} else {
					setActiveSection(pendingClickSectionId);
				}
				return;
			}

			setActiveSection(getScrollDrivenSectionId());
		}

		function scheduleUpdate() {
			if (frameRequested) {
				return;
			}

			frameRequested = true;
			window.requestAnimationFrame(() => {
				frameRequested = false;
				update();
			});
		}

		function handleNavigationClick(event) {
			event.preventDefault();

			const link = event.currentTarget;
			const href = link.getAttribute('href');
			if (!href || !href.startsWith('#')) {
				return;
			}

			const targetSectionId = href.slice(1);
			if (!sectionById.has(targetSectionId)) {
				return;
			}

			const targetSection = sectionById.get(targetSectionId);
			if (!targetSection) {
				return;
			}

			pendingClickSectionId = targetSectionId;
			pendingTargetScrollY = getTargetScrollY(targetSection);
			setActiveSection(targetSectionId);

			if (window.location.hash !== `#${targetSectionId}`) {
				window.history.pushState(null, '', `#${targetSectionId}`);
			}

			window.scrollTo({
				top: pendingTargetScrollY,
				behavior: 'smooth',
			});
			scheduleUpdate();
		}

		function handleUserInterrupt() {
			if (!pendingClickSectionId) {
				return;
			}

			clearPendingTarget();
			scheduleUpdate();
		}

		function handleKeyDown(event) {
			if (interruptKeys.has(event.key) || event.code === 'Space') {
				handleUserInterrupt();
			}
		}

		navLinks.forEach((link) => {
			link.addEventListener('click', handleNavigationClick);
		});

		window.addEventListener('scroll', scheduleUpdate, { passive: true });
		window.addEventListener('resize', scheduleUpdate);
		window.addEventListener('hashchange', scheduleUpdate);
		window.addEventListener('wheel', handleUserInterrupt, { passive: true });
		window.addEventListener('touchmove', handleUserInterrupt, { passive: true });
		window.addEventListener('keydown', handleKeyDown);

		if ('ResizeObserver' in window) {
			const resizeObserver = new ResizeObserver(() => {
				updateHeaderOffsetVar();
				scheduleUpdate();
			});
			resizeObserver.observe(header);
		}

		updateHeaderOffsetVar();
		update();
	});
	</script>
</body>
</html>
